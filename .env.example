# ──────────────────────────────────────────────────────────────────────────────
# Titan Cosmetic – Environment Variables
# Copy this file to .env.local for local development.
# Never commit real secrets. Set production values via CI/CD secrets.
# ──────────────────────────────────────────────────────────────────────────────

# App
VITE_APP_NAME=Titan Cosmetic
VITE_APP_ENV=development        # development | staging | production

# API (future backend integration)
# VITE_API_BASE_URL=https://api.titancosmetic.com/v1

# Payments (future Stripe integration)
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Analytics (future integration)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Feature flags
# VITE_ENABLE_REVIEWS=false
# VITE_ENABLE_ACCOUNTS=false
